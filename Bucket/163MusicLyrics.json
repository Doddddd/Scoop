        "}",
        "Get-ChildItem \"$dir\\MusicLyricApp*.exe\" | Rename-Item -NewName 'MusicLyricApp.exe'"
    ],
    "shortcuts": [
        [
            "MusicLyricApp.exe",
            "163MusicLyrics"
        ]
    ],
