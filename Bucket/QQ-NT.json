{
    "version": "https://updatecdn.meeting.qq.com/cos/8f7e8eb310e659ebfefeed2a79ddeaca/TencentMeeting_0300000000_3.35.1.435.publish.officialwebsite.exe\",\"version\":\"3.35.1.435\"",
    "description": "QQ-NT",
    "homepage": "https://im.qq.com",
    "license": "Freeware",
    "url": "https://dldir1.qq.com/qqfile/qq/QQNT/Windows/QQ_3.35.1.435__x64_01.exe#/dl.7z",
    "shortcuts": [
        [
            "Files\\QQ.exe",
            "QQ-NT"
        ]
    ],
    "persist": "QQ Files",
    "checkver": {
        "script": [
            "$url = 'https://im.qq.com/pcqq/index.shtml'",
            "$resp = Invoke-WebRequest -Uri $url",
            "$cont = $resp.Content",
            "$pattern = 'https://qq-web.cdn-go.cn.*windowsDownloadUrl.js'",
            "$jsUrl = [regex]::Match($cont, $pattern).Value",
            "Invoke-WebRequest -Uri $jsUrl"
        ],
        "regex": "QQNT/Windows/QQ_([\\d\\.]+)_([\\d]+)_x86_01.exe",
        "replace": "${1}.${2}"
    },
    "autoupdate": {
        "url": "https://dldir1.qq.com/qqfile/qq/QQNT/Windows/QQ_$match1_$match2_x64_01.exe#/dl.7z"
    }
}
